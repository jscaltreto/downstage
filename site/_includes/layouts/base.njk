<!doctype html>
<html lang="en" data-editor-base="{{ '/editor/' | url }}">
  {% set stylesPath = assetManifest.styles or '/assets/styles.css' %}
  {% set scriptPath = assetManifest.script or '/assets/main.js' %}
  {% set siteOrigin = 'https://www.getdownstage.com' %}
  {% set pageTitle = title or 'Downstage' %}
  {% set pageDescription = description or 'Downstage helps playwrights write in plain text, render clean manuscripts, and keep revision history readable.' %}
  {% set pageUrl = siteOrigin ~ page.url %}
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDescription }}">
    <link rel="canonical" href="{{ pageUrl }}">
    <link rel="icon" type="image/png" href="{{ '/favicon.png' | url }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Downstage">
    <meta property="og:title" content="{{ pageTitle }}">
    <meta property="og:description" content="{{ pageDescription }}">
    <meta property="og:url" content="{{ pageUrl }}">
    <meta property="og:image" content="{{ siteOrigin }}/downstage_logo.png">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ pageTitle }}">
    <meta name="twitter:description" content="{{ pageDescription }}">
    <meta name="twitter:image" content="{{ siteOrigin }}/downstage_logo.png">
    <link rel="stylesheet" href="{{ stylesPath | url }}">
  </head>
  <body class="{{ bodyClass | default('') }}">
    {{ content | safe }}
    <script src="{{ scriptPath | url }}"></script>
  </body>
</html>
