{% set cardGridClasses = "grid gap-4 pt-6 md:grid-cols-2" %}
{% if section.data.cardsClass == "tool-grid" %}
  {% set cardGridClasses = "grid gap-4 pt-6" %}
{% endif %}
<section class="rounded-panel border border-brass-500/20 bg-[linear-gradient(160deg,rgba(127,39,24,0.42),transparent_35%),rgba(66,39,31,0.96)] shadow-stage backdrop-blur-xl" id="{{ section.data.id }}">
  <div class="grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)]">
  <div class="border-b border-white/10 p-6 lg:border-b-0 lg:border-r lg:p-8">
    <p class="mb-2 text-xs font-bold uppercase tracking-[0.16em] text-brass-300">{{ section.data.kicker }}</p>
    <h2 class="font-serif text-3xl leading-tight text-parchment-200 sm:text-[2rem]">{{ section.data.title }}</h2>
  </div>
  <div class="prose-block p-6 lg:p-8">
    <div class="prose-block">{{ section.templateContent | safe }}</div>

    {% if section.data.cards %}
      <div class="{{ cardGridClasses }}">
        {% for card in section.data.cards %}
          <article class="rounded-[20px] border border-white/10 bg-white/[0.03] p-5">
            <h3 class="font-serif text-2xl text-parchment-200">{{ card.title }}</h3>
            <p class="card-copy">{{ card.text }}</p>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.data.steps %}
      <div class="my-5 grid gap-4">
        {% asyncEach step in section.data.steps %}
          <article class="grid gap-4 rounded-[22px] border border-white/10 bg-white/[0.03] p-5 md:grid-cols-[auto_minmax(0,1fr)]">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-brass-500 to-brass-400 font-extrabold text-ember-850">{{ loop.index }}</span>
            <div>
              <h3 class="font-serif text-2xl text-parchment-200">{{ step.title }}</h3>
              {% if step.text %}<p class="mt-2 text-base leading-7 text-parchment-300">{{ step.text }}</p>{% endif %}
              {% if step.code %}{% renderCodeBlock step.code, (step.codeLang or "text"), (step.codeLabel or step.codeLang or "text") %}{% endif %}
              {% if step.after %}<p class="mt-2 text-base leading-7 text-parchment-300">{{ step.after }}</p>{% endif %}
              {% if step.extraCode %}{% renderCodeBlock step.extraCode, (step.extraCodeLang or step.codeLang or "text"), (step.extraCodeLabel or step.extraCodeLang or step.codeLang or "text") %}{% endif %}
            </div>
          </article>
        {% endeach %}
      </div>
    {% endif %}

    {% if section.data.workflow %}
      <div class="my-5 grid gap-4">
        {% for item in section.data.workflow %}
          <div class="rounded-[20px] border border-white/10 bg-white/[0.03] p-5">
            <h3 class="font-serif text-2xl text-parchment-200">{{ item.title }}</h3>
            <p class="mt-2 text-base leading-7 text-parchment-300">{{ item.text }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.data.examplePairs %}
      <div class="grid gap-4">
        {% asyncEach item in section.data.examplePairs %}
          <div>
            {% if item.text %}<p class="mt-2 text-base leading-7 text-parchment-300">{{ item.text | safe }}</p>{% endif %}
            {% renderCodeBlock item.code, (item.lang or "text"), (item.label or item.lang or "text") %}
          </div>
        {% endeach %}
      </div>
    {% endif %}

    {% if section.data.examples %}
      <div class="grid gap-4">
        {% asyncEach example in section.data.examples %}
          {% set lang = "text" %}
          {% set label = "text" %}
          {% if section.data.examplesLangs and section.data.examplesLangs[loop.index0] %}
            {% set lang = section.data.examplesLangs[loop.index0] %}
          {% elseif section.data.exampleLang %}
            {% set lang = section.data.exampleLang %}
          {% endif %}
          {% if section.data.exampleLabels and section.data.exampleLabels[loop.index0] %}
            {% set label = section.data.exampleLabels[loop.index0] %}
          {% elseif section.data.exampleLabel %}
            {% set label = section.data.exampleLabel %}
          {% else %}
            {% set label = lang %}
          {% endif %}
          {% renderCodeBlock example, lang, label %}
        {% endeach %}
      </div>
    {% endif %}

    {% if section.data.code %}
      {% renderCodeBlock section.data.code, (section.data.codeLang or "text"), (section.data.codeLabel or section.data.codeLang or "text") %}
    {% endif %}

    {% if section.data.caption %}
      <p class="-mt-1 text-sm text-parchment-300">{{ section.data.caption }}</p>
    {% endif %}

    {% if section.data.list %}
      <ul class="inline-list">
        {% for item in section.data.list %}
          <li>{{ item | safe }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if section.data.callout %}
      <div class="callout">
        <strong>{{ section.data.callout.title }}</strong> {{ section.data.callout.text | safe }}
      </div>
    {% endif %}

    {% if section.data.tableRows %}
      <div class="syntax-table" role="table" aria-label="{{ section.data.tableLabel }}">
        <div class="syntax-row syntax-header" role="row">
          <span role="columnheader">{{ section.data.tableHeaders[0] }}</span>
          <span role="columnheader">{{ section.data.tableHeaders[1] }}</span>
        </div>
        {% for row in section.data.tableRows %}
          <div class="syntax-row" role="row">
            <code role="cell">{{ row[0] }}</code>
            <span role="cell">{{ row[1] }}</span>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.data.actions %}
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        {% for action in section.data.actions %}
          <a class="{% if action.kind == 'primary' %}button-primary{% else %}button-secondary{% endif %}" href="{{ action.href }}">{{ action.label }}</a>
        {% endfor %}
      </div>
    {% endif %}

    {% if bodyClass == "docs-page" %}
      <p class="mt-5 text-right text-sm">
        <a class="text-brass-300 underline decoration-brass-500/40 underline-offset-4" href="#top">Back to top</a>
      </p>
    {% endif %}
  </div>
  </div>
</section>
