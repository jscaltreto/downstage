---
layout: layouts/base.njk
title: Downstage Docs
description: The Downstage docs have moved. Redirecting to the Syntax Guide.
permalink: /docs/
eleventyExcludeFromCollections: true
---
{% set faqUrl = '/faq/' | url %}
{% set syntaxUrl = '/syntax/' | url %}
<script>
  (function () {
    // The old /docs/ page had every section on one page. We split those
    // sections across /syntax/ (the language reference) and /faq/
    // (orientation). Send each anchor to the page that now owns it so old
    // bookmarks and external deep links keep working.
    var faqIds = {
      overview: 1,
      "why-downstage": 1,
      "getting-started": 1,
      "first-workflow": 1,
      acknowledgements: 1
    };
    var faqUrl = {{ faqUrl | dump | safe }};
    var syntaxUrl = {{ syntaxUrl | dump | safe }};
    var hash = window.location.hash.replace(/^#/, "");
    var target = hash && Object.prototype.hasOwnProperty.call(faqIds, hash) ? faqUrl : syntaxUrl;
    if (hash) target += "#" + hash;
    window.location.replace(target);
  })();
</script>
<noscript>
  <meta http-equiv="refresh" content="0; url={{ syntaxUrl }}">
</noscript>
<link rel="canonical" href="{{ syntaxUrl }}">
<p class="p-6 text-parchment-300">
  The Downstage docs moved. Redirecting to the
  <a class="text-brass-300 underline" href="{{ syntaxUrl }}">Syntax Guide</a>.
</p>
