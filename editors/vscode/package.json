{
  "name": "downstage-vscode",
  "displayName": "Downstage",
  "description": "Write stage plays in plain text, preview pages, and export clean PDFs.",
  "version": "0.0.1",
  "publisher": "jscaltreto",
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "homepage": "https://www.getdownstage.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/jscaltreto/downstage.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/jscaltreto/downstage/issues"
  },
  "markdown": "github",
  "pricing": "Free",
  "qna": false,
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "downstage",
    "playwriting",
    "theatre",
    "stage-play",
    "scriptwriting",
    "manuscript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "downstage.newPlay",
        "title": "Downstage: New Play"
      },
      {
        "command": "downstage.openSamplePlay",
        "title": "Downstage: Open Sample Play"
      },
      {
        "command": "downstage.openWelcome",
        "title": "Downstage: Open Start Guide"
      },
      {
        "command": "downstage.openHelp",
        "title": "Downstage: Open Help"
      },
      {
        "command": "downstage.restartLanguageServer",
        "title": "Downstage: Restart Downstage"
      },
      {
        "command": "downstage.renderCurrentScript",
        "title": "Downstage: Export Manuscript PDF"
      },
      {
        "command": "downstage.renderCondensedScript",
        "title": "Downstage: Export Acting Edition PDF"
      },
      {
        "command": "downstage.renderCondensedScript2Up",
        "title": "Downstage: Export Acting Edition PDF (2-Up)"
      },
      {
        "command": "downstage.renderCondensedScriptBooklet",
        "title": "Downstage: Export Acting Edition PDF (Booklet)"
      },
      {
        "command": "downstage.previewCurrentScript",
        "title": "Downstage: Open Manuscript PDF Preview"
      },
      {
        "command": "downstage.previewCondensedScript",
        "title": "Downstage: Open Acting Edition PDF Preview"
      },
      {
        "command": "downstage.livePreview",
        "title": "Downstage: Open Live Preview"
      }
    ],
    "configuration": {
      "title": "Downstage",
      "properties": {
        "downstage.server.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to the `downstage` executable used to launch the language server. When empty, the extension prefers its bundled binary and falls back to `PATH`."
        },
        "downstage.server.trace": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "markdownDescription": "Trace communication between VS Code and the Downstage language server."
        },
        "downstage.editor.autoSuggestCharacterCues": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Automatically trigger character cue suggestions on an empty line after a blank separator in scene context."
        },
        "downstage.render.style": {
          "type": "string",
          "enum": [
            "standard",
            "condensed"
          ],
          "default": "standard",
          "markdownDescription": "Default export style. `standard` creates a Manuscript PDF. `condensed` creates an Acting Edition PDF."
        },
        "downstage.render.pageSize": {
          "type": "string",
          "enum": [
            "letter",
            "a4"
          ],
          "default": "letter",
          "markdownDescription": "Default PDF page size for manuscript and acting edition export."
        },
        "downstage.render.bookletGutter": {
          "type": "string",
          "default": "0.125in",
          "markdownDescription": "Inside gutter for booklet-layout Acting Edition export (e.g. `0.125in` or `3mm`). Booklet output is duplex: print double-sided, then fold in half."
        },
        "downstage.render.openAfterRender": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Open the generated PDF after a successful render."
        },
        "downstage.preview.debounceMs": {
          "type": "number",
          "default": 300,
          "markdownDescription": "Delay in milliseconds before re-rendering the live preview after edits."
        }
      }
    },
    "languages": [
      {
        "id": "downstage",
        "aliases": [
          "Downstage",
          "downstage"
        ],
        "extensions": [
          ".ds"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "downstage",
        "path": "./snippets/downstage.code-snippets"
      }
    ],
    "grammars": [
      {
        "language": "downstage",
        "scopeName": "source.downstage",
        "path": "./syntaxes/downstage.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "package": "node ./scripts/package.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit -p ./"
  },
  "devDependencies": {
    "vitest": "^4.1.5",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.28.0",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
