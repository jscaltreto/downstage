{
  "name": "downstage-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:desktop": "cross-env DESKTOP_BUILD=true vite build --outDir ../cmd/downstage-write/frontend",
    "dev": "vite",
    "dev:desktop": "cross-env DESKTOP_BUILD=true vite",
    "preview:strict": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.10.8",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.4.27",
    "codemirror": "^6.0.1",
    "lucide-vue-next": "^1.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typo-js": "^1.3.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vue/test-utils": "^2.4.11",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.8.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "//overrides": "ws pin overrides happy-dom@20.9.0's transitive ws@8.20.0 (GHSA-58qx-3vcg-4xpx, uninitialized memory disclosure). Drop the override when happy-dom releases a version that pins ws@^8.20.1 or newer. Tracked in issue #189.",
  "overrides": {
    "ws": "^8.20.1"
  }
}
