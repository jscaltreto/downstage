{
  "name": "downstage-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "mkdir -p dist && esbuild src/main.ts --bundle --outfile=dist/bundle.js --format=esm --target=es2020",
    "watch": "esbuild src/main.ts --bundle --outfile=dist/bundle.js --format=esm --target=es2020 --watch"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.10.8",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.5",
    "codemirror": "^6.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  }
}
